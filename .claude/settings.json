{
  "env": {
    "KH_PRIVATE_DOCS_DIR": "/Users/liamj/Documents/development/knowledge-hub-docs-site"
  },
  "enabledPlugins": {
    "knowledge-hub@local": false
  },
  "permissions": {
    "allow": [
      "Bash(supabase *)",
      "Bash(/opt/homebrew/bin/supabase *)",
      "Bash(python3 -m pytest *)",
      "Bash(python3 -m playwright *)",
      "Write(.claude/skills/**)",
      "Bash(mkdir -p .claude/skills/*)",
      "Bash(mkdir -p ~/.claude/.sentinels)",
      "Bash(touch ~/.claude/.sentinels/*)",
      "Bash(ordna list)",
      "Bash(ordna list *)",
      "Bash(ordna show *)",
      "Bash(cat /Users/liamj/Documents/development/knowledge-hub-docs-site/tasks/*)",
      "Bash(git -C /Users/liamj/Documents/development/knowledge-hub-docs-site status *)",
      "Bash(git -C /Users/liamj/Documents/development/knowledge-hub-docs-site log *)",
      "Bash(git -C /Users/liamj/Documents/development/knowledge-hub-docs-site diff *)",
      "Bash(git -C /Users/liamj/Documents/development/knowledge-hub-docs-site add *)",
      "Bash(git -C /Users/liamj/Documents/development/knowledge-hub-docs-site commit *)",
      "Bash(git -C /Users/liamj/Documents/development/knowledge-hub-docs-site push)",
      "Bash(git -C /Users/liamj/Documents/development/knowledge-hub-docs-site push *)"
    ],
    "additionalDirectories": ["~/Documents/development/knowledge-hub-docs-site/**"],
    "deny": ["Read(supabase/types/database.types.ts)", "Read(lib/mcp/plugin-bundle.ts)"],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel 2>/dev/null)/.claude/hooks/bash-heredoc-preflight.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel 2>/dev/null)/.claude/hooks/ip-leak-filename-guard.sh\""
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel 2>/dev/null)/.claude/hooks/sentinel-gated-agents-skills-edit-guard.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel 2>/dev/null)/.claude/hooks/ip-leak-filename-guard.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
      "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command":"npx prettier --write $CLAUDE_FILE_PATHS 2>/dev/null || true"
            }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|clear",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel 2>/dev/null)/.claude/hooks/mempal-recall.sh\""
          }
        ]
      }
    ]
  },
  "worktree": {
    "symlinkDirectories": ["node_modules", ".venv", ".cache"]
  },
  "sandbox": {
    "network": {
      "allowedDomains": [
        "github.com",
        "*.github.com",
        "codeload.github.com",
        "objects.githubusercontent.com",
        "*.supabase.com",
        "*.supabase.co"
      ],
      "allowLocalBinding": true
    },
    "enableWeakerNetworkIsolation": true,
    "excludedCommands": ["launchctl", "lavish-axi"],
    "filesystem": {
      "disabled": true
    }
  }
}
