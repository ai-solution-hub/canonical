# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

SUPABASE_SERVICE_ROLE_KEY=your-secret-key
POSTGRES_PASSWORD=your-db-password
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Public base URL of the deployed app — used by API call sites and email templates.
NEXT_PUBLIC_APP_URL=https://your-deployment.vercel.app
# Identifies the client tenant; drives BRANDING.organisationName and downstream
# certification-holder derivation. Missing → BRANDING falls back to "Knowledge Hub" →
# corrupted entity_mention metadata in production. UK clients use a slug like `example-client`.
NEXT_PUBLIC_CLIENT_ID=slug-here

# AI
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Optional
AI_SUMMARY_MODEL=claude-sonnet-4-6

# AI pipeline overrides (optional — defaults shown)
# AI_CLASSIFICATION_MODEL=claude-opus-4-6
# AI_EMBEDDING_MODEL=text-embedding-3-large
# AI_EMBEDDING_DIMS=1024

# Integer batch size used by classification jobs.
CLASSIFICATION_BATCH_SIZE=25

# Intelligence Pipeline
FIRECRAWL_API_KEY=           # Firecrawl API key (intelligence pipeline)
CRON_SECRET=                 # Vercel Cron authentication secret

# Taxonomy sync
# Fine-scoped GitHub PAT used by taxonomy-sync and related GHA repository_dispatch flows.
GITHUB_SYNC_TOKEN=your-value-here
# Shared secret for taxonomy-sync GHA → app callback authentication.
# Generate via `openssl rand -hex 32`.
TAXONOMY_SYNC_CALLBACK_SECRET=your-value-here

# Sentry — provisioned automatically by the Vercel→Sentry integration in production.
# The integration emits these names UN-prefixed by default; using the bare names
# avoids a translation layer in CI. DSN is public; ORG and PROJECT are the
# Vercel-side names from that integration. AUTH_TOKEN is a write-credential for
# source-map upload — keep it in `.env.local` only, never in `.env` (that file is
# gitignored too, but separation reduces leak surface).
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN — set in `.env.local` only.

# E2E
NEXT_PUBLIC_E2E=           # Set to 'true' to disable CopilotKit (E2E tests)

# Script-only auth fallback — used by `scripts/batch-reclassify.ts` when
# SUPABASE_SERVICE_ROLE_KEY is unset. Optional; keep in `.env.local` only.
# SUPABASE_AUTH_EMAIL=
# SUPABASE_AUTH_PASSWORD=

# Test users (for development)
TEST_USER_1_EMAIL=admin@example.com
TEST_USER_1_PASSWORD=...
TEST_USER_2_EMAIL=editor@example.com
TEST_USER_2_PASSWORD=...
TEST_USER_3_EMAIL=viewer@example.com
TEST_USER_3_PASSWORD=...
