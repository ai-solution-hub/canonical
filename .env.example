# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=your-secret-key
SUPABASE_DBPASSWORD=your-db-password
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Client branding — controls which config in lib/branding/clients/ is
# loaded by BRANDING.organisationName etc. Omit or leave 'default' for
# generic dev; set to 'example-client' when running classifier scripts against
# the example-client production DB (rovrymhhffssilaftdwd). Otherwise
# deriveHolderMetadata compares holds-source against "Knowledge Hub"
# instead of "Example Client Ltd" and miscategorises every cert as
# supplier-held. Eval scripts fail fast when this is misconfigured.
NEXT_PUBLIC_CLIENT_ID=example-client

# AI
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Optional
AI_SUMMARY_MODEL=claude-sonnet-4-6

# AI pipeline overrides (optional — defaults shown)
# AI_CLASSIFICATION_MODEL=claude-opus-4-6
# AI_EMBEDDING_MODEL=text-embedding-3-large
# AI_EMBEDDING_DIMS=1024

# Intelligence Pipeline
FIRECRAWL_API_KEY=           # Firecrawl API key (intelligence pipeline)
CRON_SECRET=                 # Vercel Cron authentication secret

# Sentry
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# E2E
NEXT_PUBLIC_E2E=           # Set to 'true' to disable CopilotKit (E2E tests)

# Test users (for development)
TEST_USER_1_EMAIL=admin@example.com
TEST_USER_1_PASSWORD=...
TEST_USER_2_EMAIL=editor@example.com
TEST_USER_2_PASSWORD=...
TEST_USER_3_EMAIL=viewer@example.com
TEST_USER_3_PASSWORD=...
