# deploy/coolify/.env.staging.example
#
# ID-66.21: env-var template for the STAGING Coolify cocoindex stack
#           (deploy/coolify/docker-compose.staging.yaml).
#
# PURPOSE: names + SAFE PLACEHOLDER values + a one-line comment per var. This file is the
# env contract the operator pastes (with real staging values) into Coolify's per-app
# encrypted env when standing up the staging app. See:
#   - deploy/coolify/docker-compose.staging.yaml  (the compose template)
#   - docs/runbooks/staging-coolify-cocoindex.md  (stand-up runbook)
#   - docs/runbooks/onprem-secrets-migration.md   (GCP Secret Manager → Coolify mapping)
#
# NEVER commit real secret values. Everything below is a PLACEHOLDER. In Coolify, mark
# every secret row (API keys, DSN, tokens, admin creds) as secret/encrypted; only
# PULLMD_SERVICE_URL is a non-secret plaintext value and it is already baked into the
# compose file (not listed here).
#
# STAGING vs PROD: the SUPABASE_* values and COCOINDEX_DB_DSN below MUST target the
# STAGING Supabase branch — NOT the prod project.

# --- Pinned image tag (REQUIRED — compose refuses to start if unset) ---
# A pinned sha- tag from the {66.7} onprem-deploy.yml GH Action (never :latest). Staging
# may pin a release-candidate ahead of prod to validate it first.
COCOINDEX_IMAGE_TAG=sha-REPLACE_WITH_PINNED_SHA
# GHCR owner org for the image path (defaults to ai-solution-hub in the compose if unset).
GHCR_OWNER=ai-solution-hub

# --- Corpus / walk-trigger control ---
# ID-83 / bl-221: this MAY now stay SET permanently to the STAGING corpus path
# (e.g. /cocoindex-state/corpus). Boot NO LONGER walks the corpus — the worker
# boots lifespan-only (coco.start_blocking(), no walk) and the corpus walk fires
# ONLY via the on-demand POST /walk trigger (a Coolify scheduled task or a
# supervised operator curl). A deploy/restart is burn-safe regardless of this
# value — the SOURCE_PATH-blanking burn-valve is RETIRED. Leaving it empty still
# works (/walk then returns a named 400 "nothing to walk"). Stand up the Coolify
# scheduled task per docs/runbooks/onprem-b1-deploy.md §B2.
COCOINDEX_SOURCE_PATH=
# LMDB virtual map size in bytes (sparse reservation). 4 GiB default; override only if needed.
COCOINDEX_LMDB_MAP_SIZE=4294967296

# --- Boot-required STAGING Supabase pooler DSN (asyncpg) ---
# The engine's KH-owned Postgres connection string for the STAGING branch. Build it from
# the staging POSTGRES_PASSWORD and the region-qualified pooler host
# (aws-<n>-eu-west-2.pooler.supabase.com — read the aws-0/aws-1 prefix from the Supabase
# dashboard, do NOT guess). This is NOT the LMDB path. See cocoindex-deploy.md §0.1.
COCOINDEX_DB_DSN=postgresql://postgres.<staging-project-ref>:REPLACE_PASSWORD@aws-0-eu-west-2.pooler.supabase.com:5432/postgres

# --- Pipeline webhook (best-effort POST after a run) ---
# For STAGING this should target the STAGING app host's pipeline-runs record endpoint
# (the staging Vercel deployment), reconciled with the {66.13} cutover plan — NOT the prod
# app URL. Read by flow.py:_emit_pipeline_run_webhook. Leave commented/empty until {66.13}
# confirms the staging repoint.
PIPELINE_RUN_WEBHOOK_URL=https://knowledge-hub-git-staging-tw-group.vercel.app/api/internal/pipeline-runs/record
# Shared secret authenticating the inbound pipeline-runs/record webhook (Vercel Cron secret).
CRON_SECRET=REPLACE_WITH_STAGING_CRON_SECRET

# --- LLM / embeddings provider keys ---
ANTHROPIC_API_KEY=sk-ant-REPLACE
OPENAI_API_KEY=sk-REPLACE

# --- STAGING Supabase project keys (staging branch) ---
SUPABASE_URL=https://<staging-project-ref>.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_STAGING
SUPABASE_SERVICE_ROLE_KEY=REPLACE_STAGING_SERVICE_ROLE_KEY
NEXT_PUBLIC_SUPABASE_URL=https://<staging-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_STAGING
# Public origin of the STAGING app deployment (used by call sites / metadata).
NEXT_PUBLIC_APP_URL=https://knowledge-hub-git-staging-tw-group.vercel.app

# --- Error reporting ---
# Sentry source-map upload write credential (shared across envs; runtime tag via NODE_ENV).
SENTRY_AUTH_TOKEN=REPLACE_SENTRY_AUTH_TOKEN

# --- pullmd service secrets (single-admin bootstrap; boot-required for pullmd) ---
PULLMD_ADMIN_EMAIL=admin@example.com
PULLMD_ADMIN_PASSWORD=REPLACE_PULLMD_ADMIN_PASSWORD
# Shared Bearer token: cocoindex sends it; pullmd validates it. Same value in both apps.
PULLMD_API_TOKEN=REPLACE_PULLMD_API_TOKEN
