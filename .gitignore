# Dependencies
node_modules/
.next/

# Environment
.env
.env.local
.env*.local
.env*.old-project-backup
.env*-backup
.env.bak
!.env.example
.mcp.json

# Python
__pycache__/
*.pyc
.venv/
venv/

# Claude Code workspace — selective tracking (S157 WP4)
# Blanket-ignore everything under .claude/ by default to protect per-machine
# state (settings.local.json, worktree metadata) and prevent marketplace-
# sourced skills/plugins from being pinned in git. Track explicit project-
# specific paths via the `!` un-ignores below.
# See docs/audits/s157-claude-dot-tracking-audit.md for the classification
# of which subdirectories are project-specific vs marketplace-sourced.
.claude/*

# Project-specific files we want tracked
!.claude/checks/
!.claude/hooks/
!.claude/settings.json

# Local knowledge-hub plugin (tracked). Marketplace plugins
# (customer-support, design, enterprise-search, operations,
# product-management, productivity, sales) stay ignored.
!.claude/plugins/
.claude/plugins/*
!.claude/plugins/knowledge-hub/

# Project-specific skills (tracked). Marketplace skills (frontend-design,
# mcp-builder, ast-grep, context-engineering-collection, create-mcp-app,
# llm-evaluation, markdown-converter, prompt-engineering-patterns,
# supabase-postgres-best-practices, vercel-react-best-practices,
# writing-skills) stay ignored.
!.claude/skills/
.claude/skills/*
!.claude/skills/handoff/
!.claude/skills/review/
!.claude/skills/start-session/
!.claude/skills/update-docs/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Git worktrees
.worktrees/

# Agent browser state
.agent-browser/

# TheHook knowledge capture
.thehook/

# Playwright MCP
.playwright-mcp/

# Playwright E2E
playwright-report/
test-results/
e2e/.auth/

# Supabase local
supabase/.temp/

# MCP App build artifacts (regenerated by bun run build:mcp-apps)
mcp-apps/*/dist/
mcp-apps/*/node_modules/

# Build output
out/
next-env.d.ts
tsconfig.tsbuildinfo
package-lock.json

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Turbopack
.turbo/

# Vercel
.vercel

# Logs
logs/
*.log

# CSV data files
*.csv
!supabase/**/*.csv
.firecrawl/

# Database backups
backups/
test-data/

# Quality protocol snapshots (large JSONL with 1024-dim embeddings)
data/*
# …except the example-client markdown corpus regenerated from production for re-ingestion.
!data/example-client-markdown-reingest/

# Session output dumps (Claude Code session exports)
output.jsonl
*-session-output.jsonl
*_session_output.json
*-session-output.json
/docs/database/

# Graphify baseline outputs — too big for git, regenerable from run_baseline.py
.planning/codebase/graphify-baselines/*/graph.json
.planning/codebase/graphify-baselines/*/graph.html
.planning/codebase/graphify-baselines/*/graphify-out/

# graphify-out from incidental graphify runs (project root + client-doc subdir)
/graphify-out/
docs/client-documentation/graphify-out/

# MemPalace per-project files (issue #185)
mempalace.yaml
entities.json
.spike-s15/
