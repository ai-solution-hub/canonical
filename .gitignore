# Dependencies
node_modules/
.next/

# Environment
.env
.env.local
.env*.local
.env*.old-project-backup
.env*-backup
.env.bak
!.env.example
.mcp.json

# Python
__pycache__/
*.pyc
.venv/
venv/

# Project-specific files we want tracked
!.claude/agents/
!.claude/checks/
!.claude/hooks/
!.claude/skills/
!.claude/plugins/
!.claude/settings.json

# Session-driver-cmux runtime state (per-worker event streams + worktrees).
# Both are blanket-ignored by .claude/* above; listing explicitly to document
# intent and so newcomers don't try to track them.
.claude/cmux-events/
.claude/cmux-briefs/
.claude/scheduled_tasks.lock
.claude/worktrees/

# Worktree symlinkDirectories artefacts
/node_modules
/.venv
/.bin
/.cache

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Git worktrees
.worktrees/

# Agent browser state
.agent-browser/

# Playwright MCP
.playwright-mcp/

# Playwright E2E
playwright-report/
test-results/
e2e/.auth/

# Supabase local
supabase/.temp/

# MCP App build artifacts (regenerated by bun run build:mcp-apps)
mcp-apps/*/dist/
mcp-apps/*/node_modules/

# Build output
out/
next-env.d.ts
tsconfig.tsbuildinfo
*.tsbuildinfo
package-lock.json

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Turbopack
.turbo/

# Vercel
.vercel

# Logs
logs/
*.log

# CSV data files
*.csv
!supabase/**/*.csv

# Session output dumps (Claude Code session exports)
output.jsonl
*-session-output.md
*_session_output.md
*-session-output.jsonl
*_session_output.json
*-session-output.json
/docs/database/

# MemPalace
mempalace.yaml
entities.json

# GitNexus (CLAUDE.md is tracked; the rest of the directory is ignored)
.gitnexus/**
!.gitnexus/CLAUDE.md

# AST Dataflow (CLAUDE.md is tracked; the rest of the directory is ignored)
.ast-dataflow/**
!.ast-dataflow/CLAUDE.md
# CocoIndex Code (ccc)
/.cocoindex_code/

# Ledger-mirror regen cache (scripts/regen-mirrors.sh — task-view clones)
.cache/
lib/branding/client-branding-map.generated.ts
.type-drift-report.md

# ID-95 PI-15: client-provenance entity_aliases snapshot is point-of-use generated (deploy), never committed
scripts/tests/fixtures/entity_aliases_snapshot.json

# ID-95 PI-18 {95.13}
# DSNs
scripts/.propagation-catalog.json

# Local session ephemera (Lavish review artifacts, user scratch dir)
.lavish/
.user-scratch/

# Client branding overlay (ID-68.22): deploy-time fetch output is never
# re-committed to the public tree. default.json is the only tracked client
# config; private client JSON + assets land here at build via
# scripts/fetch-client-branding.ts (ID-95) and must stay untracked.
/lib/branding/clients/*.json
!/lib/branding/clients/default.json
/public/clients/*

# jscpd raw report + parser output are regenerable via: bun run dupe-check;
# the *.md analysis files (AUDIT-REPORT + per-area audits) are the tracked deliverable.
docs/reports/jscpd-report/*.json
docs/reports/jscpd-report/parse-analysis.py
