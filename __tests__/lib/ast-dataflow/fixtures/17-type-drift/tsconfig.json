{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    },
    "skipLibCheck": true
  },
  "include": [
    "types/**/*.ts",
    "lib/**/*.ts",
    "app/**/*.ts",
    "__tests__/**/*.ts"
  ]
}
