{
  "metadata": {
    "version": "5.0",
    "created": "08/03/2026",
    "updated": "03/04/2026",
    "description": "Search evaluation test suite for Knowledge Hub hybrid search (pgvector + keyword + recency via hybrid_search RPC). Updated for expanded taxonomy (15 domains, 56 subtopics). Relevance judgements added from live DB content. 4 subtopics added in S80: health-and-safety, environmental, modern-slavery, supply-chain. 8 new domains added via sector intelligence: market-intelligence, legislation-policy, products-services, sector-news, education, multi-academy-trusts, safeguarding-adults, safeguarding-child-protection.",
    "search_endpoint": "POST /api/search",
    "search_defaults": {
      "threshold": 0.35,
      "limit": 20
    },
    "app_url": "http://localhost:6100/search",
    "taxonomy": {
      "domains": [
        "compliance",
        "corporate",
        "education",
        "implementation",
        "legislation-policy",
        "market-intelligence",
        "methodology",
        "multi-academy-trusts",
        "product-feature",
        "products-services",
        "safeguarding-adults",
        "safeguarding-child-protection",
        "sector-news",
        "security",
        "support"
      ],
      "content_types": [
        "article",
        "blog",
        "pdf",
        "note",
        "research",
        "other",
        "q_a_pair",
        "case_study",
        "policy",
        "certification",
        "compliance",
        "methodology",
        "capability",
        "product_description"
      ]
    },
    "relevance_scale": {
      "0": "not relevant",
      "1": "marginally relevant",
      "2": "relevant",
      "3": "highly relevant"
    },
    "notes": "All test cases use realistic UK bid management search queries. Default threshold is 0.35. The hybrid_search RPC combines embedding similarity (70%) + title match (15%) + keyword match (10%) + summary/author (5%) + recency (5%). Content is primarily Q&A pairs from bid libraries. Relevance judgements use real content_item IDs from the live database."
  },
