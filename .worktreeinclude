# Files copied into each new git worktree created by Claude Code.
# Syntax is .gitignore-style; entries only copy if they match a pattern
# AND are gitignored (tracked files are never duplicated).
# Docs: https://code.claude.com/docs/en/worktrees#copy-gitignored-files-into-worktrees

# Dependencies
# NB: node_modules/ and .next/ are intentionally NOT copied here. The cmux
# session-driver launch-worker.sh treats every line as a LITERAL path and does
# `cp -R` (no gitignore-style matching), so listing the 1.1G node_modules + 1.1G
# .next caused a ~6.6GB recursive copy across 3 worker worktrees. Workers now get
# node_modules via launch-worker's `--symlink-deps` (symlink, shared); .next
# regenerates on demand. (S384, Liam-approved.)
# node_modules/
# .next/

# Environment
.env.local

# Session-driver-cmux
.claude/cmux-events/
.claude/cmux-briefs/
.claude/scheduled_tasks.lock

# Agent browser state
.agent-browser/

