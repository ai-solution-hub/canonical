# Files copied into each new git worktree created by Claude Code.
# Syntax is .gitignore-style; entries only copy if they match a pattern
# AND are gitignored (tracked files are never duplicated).
# Docs: https://code.claude.com/docs/en/worktrees#copy-gitignored-files-into-worktrees

# Dependencies
# NB: node_modules/ and .next/ are intentionally NOT copied here. node_modules
# is symlinked via settings.json worktree.symlinkDirectories (native) and
# scripts/provision-worktree.sh (top-level worktrees + launch-worker); .next
# regenerates on demand. scripts/provision-worktree.sh treats each remaining
# entry below as a LITERAL path and `cp -R`s it (no gitignore-style glob
# matching beyond the special-cased .gitnexus/ skip), so listing the 1.1G
# node_modules + 1.1G .next here would force a ~6.6GB recursive copy across
# worker worktrees. (S384, Liam-approved.)

# Environment
.env.local

# Agent browser state
.agent-browser/

# Playwright MCP
.playwright-mcp/

# Playwright E2E
playwright-report/
test-results/
e2e/.auth/

# Supabase local
supabase/.temp/

# Build output
tsconfig.tsbuildinfo

# Code-intelligence
# .gitnexus holds a TRACKED CLAUDE.md, so native worktree creation cannot
# symlink it (symlinkDirectories whole-dir symlink would shadow the tracked
# file) and falls back to a full ~370M `lbug` copy via this entry. That copy is
# the cost native pays for a working in-worktree index. scripts/provision-worktree.sh
# (top-level worktrees + launch-worker) is smarter: it symlinks only lbug+meta.json
# inside a real .gitnexus/ and SKIPS this copy. Keep the entry for the native path.
.gitnexus/**

# Memory
mempalace.yaml
entities.json

