# Files copied into each new git worktree created by Claude Code.
# Syntax is .gitignore-style; entries only copy if they match a pattern
# AND are gitignored (tracked files are never duplicated).
# Docs: https://code.claude.com/docs/en/worktrees#copy-gitignored-files-into-worktrees

.env.local

# Code-intelligence indexes — copy into agent worktrees so gitnexus_detect_changes
# + ccc search resolve locally (worktrees otherwise inherit no index).
# gitnexus_impact already works via the primary-tree index without these.
# Cost note: ~260MB (.gitnexus) + ~412MB (.cocoindex_code) copied per worktree.
# (.gitnexus/CLAUDE.md is tracked → comes via git, not copied here.)
.gitnexus/**
.cocoindex_code/**
