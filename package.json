    "react-dom": "19.2.7",
    "react-dropzone": "^15.0.0",
    "react-pdf": "^10.4.1",
    "react-resizable-panels": "^4.11.2",
    "rss-parser": "^3.13.0",
    "server-only": "^0.0.1",
    "signature_pad": "^5.1.3",
    "sonner": "^2.0.7",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "ts-morph": "^28.0.0",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "unpdf": "^1.6.2",
