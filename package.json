    "@vercel/analytics": "^2.0.1",
    "border-beam": "^1.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cytoscape": "^3.28.1",
