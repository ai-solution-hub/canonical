{
  "name": "knowledge-hub",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0 <23.0.0",
    "bun": ">=1.3.0"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "predev": "bun run generate:skills && bun run generate:content-type-values",
    "prebuild": "bun run generate:skills && bun run generate:content-type-values",
    "generate:skills": "bun run scripts/generate-skills-inline.ts",
    "generate:content-type-values": "bun run scripts/generate-content-type-values.ts",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:build": "vitest run __tests__/build",
    "test:e2e:ui": "playwright test --ui",
    "bundle:mcp-apps": "bun run scripts/bundle-mcp-apps.ts",
    "build:mcp-apps": "cd mcp-apps/coverage-matrix && bun install && INPUT=app.html bunx vite build && cd ../bid-dashboard && bun install && INPUT=app.html bunx vite build && cd ../reorient-me && bun install && INPUT=app.html bunx vite build && cd ../intelligence-feed && bun install && INPUT=app.html bunx vite build && cd ../.. && bun scripts/bundle-mcp-apps.ts",
    "build:plugin": "bun run scripts/bundle-plugin.ts",
    "sync:plugin-taxonomy": "bun run scripts/sync-plugin-taxonomy.ts",
    "sync:taxonomy": "bun run scripts/generate-classification-prompt-taxonomy.ts && bun run scripts/generate-taxonomy-snapshot.ts && bun run scripts/sync-plugin-taxonomy.ts && bun run build:plugin",
    "roadmap:to-json": "bun run scripts/roadmap-to-json.ts",
    "roadmap:render": "bun run scripts/roadmap-from-json.ts",
    "test:mcp-eval": "bun run scripts/mcp-eval/protocol-compliance.ts",
    "test:mcp-eval:skip-ai": "bun run scripts/mcp-eval/protocol-compliance.ts --skip-ai",
    "test:mcp-eval:rq": "bun run scripts/mcp-eval/response-quality.ts",
    "test:mcp-eval:rq:skip-search": "bun run scripts/mcp-eval/response-quality.ts --skip-search",
    "test:mcp-eval:fc": "bun run scripts/mcp-eval/functional-correctness.ts",
    "test:mcp-eval:fc:skip-ai": "bun run scripts/mcp-eval/functional-correctness.ts --skip-ai",
    "seed:mcp-eval": "bun run scripts/mcp-eval/seed-fixtures.ts",
    "seed:e2e-users": "bun run scripts/seed-e2e-users.ts",
    "kb-search": "bun run scripts/kb-search.ts",
    "stats": "bun run scripts/generate-codebase-stats.ts",
    "ast-dataflow": "bun run scripts/ast-dataflow-cli.ts",
    "generate:mcp-inventory": "bun run scripts/generate-mcp-inventory.ts",
    "knip": "knip --no-config-hints",
    "knip:files": "knip --no-config-hints --include files",
    "knip:exports": "knip --no-config-hints --include exports,types",
    "ci:knip-check": "bun run scripts/check-knip-baseline.ts",
    "eval:classification": "bun run scripts/eval-classification.ts",
    "eval:summarisation": "bun run scripts/eval-summarisation.ts",
    "eval:search": "bun run scripts/eval-search.ts",
    "eval:bid-drafting": "bun run scripts/eval-bid-drafting.ts",
    "eval:entity": "EVAL_ENTITY=1 bun run test __tests__/eval/entity-classification-eval.test.ts",
    "eval:all": "bun run eval:classification && bun run eval:summarisation && bun run eval:search && bun run eval:bid-drafting && bun run eval:entity",
    "dev:clean": "rm -rf .next && next dev --turbopack",
    "analyze": "ANALYZE=true next build",
    "build:vercel": "bun run generate:skills && bun run generate:content-type-values && bun run build:mcp-apps && next build",
    "db:row-count-diff": "bun run scripts/db-row-count-diff.ts",
    "cleanup:orphaned-content-history": "bun run scripts/cleanup-orphaned-content-history.ts",
    "cleanup:stale-test-artifacts": "bun run scripts/cleanup-stale-test-artifacts.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.96.0",
    "@hookform/resolvers": "^5.2.2",
    "@mendable/firecrawl-js": "^4.23.0",
    "@modelcontextprotocol/ext-apps": "^1.7.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "^0.6.0",
    "@react-pdf/renderer": "^4.5.1",
    "@sentry/nextjs": "^10.53.1",
    "@supabase/ssr": "0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-query-devtools": "^5.100.10",
    "@tanstack/react-virtual": "^3.13.24",
    "@tiptap/extension-character-count": "3.23.4",
    "@tiptap/extension-collaboration": "3.23.4",
    "@tiptap/extension-link": "3.23.4",
    "@tiptap/extension-placeholder": "3.23.4",
    "@tiptap/extension-table": "3.23.4",
    "@tiptap/extension-table-cell": "3.23.4",
    "@tiptap/extension-table-header": "3.23.4",
    "@tiptap/extension-table-row": "3.23.4",
    "@tiptap/markdown": "3.23.4",
    "@tiptap/pm": "3.23.4",
    "@tiptap/react": "3.23.4",
    "@tiptap/starter-kit": "3.23.4",
    "@vercel/analytics": "^1.6.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "diff": "^9.0.0",
    "docx": "^9.6.1",
    "dompurify": "^3.4.3",
    "exceljs": "4.4.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.575.0",
    "mammoth": "^1.12.0",
    "marked": "^17.0.4",
    "mcp-handler": "^1.1.0",
    "motion": "^12.38.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "node-html-parser": "^7.1.0",
    "openai": "^6.37.0",
    "pino": "^10.3.1",
    "pluralize": "^8.0.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-dropzone": "^15.0.0",
    "react-hook-form": "^7.75.0",
    "react-markdown": "^10.1.0",
    "react-pdf": "^10.4.1",
    "react-resizable-panels": "^4.11.1",
    "remark-gfm": "^4.0.1",
    "rss-parser": "^3.13.0",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "ts-morph": "^28.0.0",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "unpdf": "^1.6.2",
    "y-prosemirror": "^1.3.7",
    "yjs": "^13.6.30",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.150",
    "@axe-core/playwright": "^4.11.3",
    "@next/bundle-analyzer": "^16.2.6",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@tanstack/eslint-plugin-query": "^5.100.10",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25",
    "@types/pluralize": "^0.0.33",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/turndown": "^5.0.6",
    "@vitest/coverage-v8": "^4.1.6",
    "dotenv": "16",
    "eslint": "^9",
    "eslint-config-next": "^16",
    "glob": "^13.0.6",
    "jsdom": "^28.1.0",
    "knip": "^6.13.1",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.6"
  }
}
