{
  "name": "canonical",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.0.0 <23.0.0",
    "bun": ">=1.3.0"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "predev": "bun run generate:skills && bun run generate:content-type-values && bun run generate:branding",
    "prebuild": "bun run generate:skills && bun run generate:content-type-values && bun run generate:client-branding && bun run generate:branding",
    "generate:skills": "bun run scripts/generate-skills-inline.ts",
    "generate:client-branding": "bun run scripts/fetch-client-branding.ts",
    "generate:branding": "bun run scripts/generate-client-branding-map.ts",
    "generate:content-type-values": "bun run scripts/generate-content-type-values.ts",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "NODE_OPTIONS=--max-old-space-size=4096 tsc --noEmit -p tsconfig.ci.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:mutation": "bun run test:mutation:pilot",
    "test:mutation:pilot": "stryker run stryker.config.mjs",
    "test:mutation:full": "STRYKER_SCOPE=full stryker run stryker.config.mjs",
    "test:e2e": "playwright test",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:private-docs": "VITEST_PRIVATE_DOCS=1 vitest run __tests__/mcp/plugin-taxonomy-consistency.test.ts __tests__/validation/taxonomy-consistency.test.ts",
    "test:build": "vitest run __tests__/build",
    "test:e2e:ui": "playwright test --ui",
    "bundle:mcp-apps": "bun run scripts/bundle-mcp-apps.ts",
    "build:mcp-apps": "cd mcp-apps/coverage-matrix && bun install && INPUT=app.html bunx vite build && cd ../form-dashboard && bun install && INPUT=app.html bunx vite build && cd ../reorient-me && bun install && INPUT=app.html bunx vite build && cd ../intelligence-feed && bun install && INPUT=app.html bunx vite build && cd ../.. && bun scripts/bundle-mcp-apps.ts",
    "build:plugin": "bun run scripts/bundle-plugin.ts",
    "sync:plugin-taxonomy": "bun run scripts/sync-plugin-taxonomy.ts",
    "sync:taxonomy": "bun run scripts/generate-classification-prompt-taxonomy.ts && bun run scripts/generate-taxonomy-snapshot.ts && bun run scripts/sync-plugin-taxonomy.ts && bun run build:plugin",
    "test:mcp-eval": "bun run scripts/mcp-eval/protocol-compliance.ts",
    "test:mcp-eval:skip-ai": "bun run scripts/mcp-eval/protocol-compliance.ts --skip-ai",
    "test:mcp-eval:rq": "bun run scripts/mcp-eval/response-quality.ts",
    "test:mcp-eval:rq:skip-search": "bun run scripts/mcp-eval/response-quality.ts --skip-search",
    "test:mcp-eval:fc": "bun run scripts/mcp-eval/functional-correctness.ts",
    "test:mcp-eval:fc:skip-ai": "bun run scripts/mcp-eval/functional-correctness.ts --skip-ai",
    "seed:mcp-eval": "bun run scripts/mcp-eval/seed-fixtures.ts",
    "register:id71-touchpoints": "bun run scripts/eval-register-id71-touchpoints.ts --register",
    "seed:e2e-users": "bun run scripts/seed-e2e-users.ts",
    "kb-search": "bun run scripts/kb-search.ts",
    "ast-dataflow": "bun run tools/ast-dataflow/cli.ts",
    "ast-dataflow-py": "python3 tools/ast_dataflow_py/cli.py",
    "gitnexus:analyze": "bun run scripts/gitnexus-analyze.ts",
    "dupe-check": "jscpd . --pattern \"**/*.{ts,tsx,js,jsx,py}\"",
    "knip": "knip --no-config-hints",
    "knip:files": "knip --no-config-hints --include files",
    "knip:exports": "knip --no-config-hints --include exports,types",
    "ci:knip-check": "bun run scripts/check-knip-baseline.ts",
    "check:migration-fn-table-refs": "bun run scripts/check-migration-fn-table-refs.ts",
    "eval:classification": "bun run scripts/eval-classification.ts",
    "eval:search": "bun run scripts/eval-search.ts",
    "eval:procurement-drafting": "bun run scripts/eval-procurement-drafting.ts",
    "eval:entity": "bun run scripts/eval-entity-classification.ts",
    "eval:all": "bun run eval:classification && bun run eval:search && bun run eval:procurement-drafting && bun run eval:entity",
    "dev:clean": "rm -rf .next && next dev --turbopack",
    "analyze": "ANALYZE=true next build",
    "build:vercel": "bun run generate:skills && bun run generate:content-type-values && bun run generate:client-branding && bun run generate:branding && bun run build:mcp-apps && next build",
    "db:row-count-diff": "bun run scripts/db-row-count-diff.ts",
    "cleanup:stale-test-artifacts": "bun run scripts/cleanup-stale-test-artifacts.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.112.1",
    "@base-ui/react": "^1.4.1",
