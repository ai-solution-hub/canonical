{
  "pattern": "**/*.{ts,tsx,js,jsx,py}",
  "threshold": 5,
  "reporters": ["json", "console"],
  "output": "docs/reports/jscpd-report",
  "gitignore": false,
  "ignore": [
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/.next/**",
    "**/coverage/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/test/**",
    "**/tests/**",
    "**/__tests__/**",
    "**/e2e/**",
    "**/*.d.ts",
    "**/*.min.js",
    "**/*.generated.*",
    "**/supabase/types/**",
    "**/database.types.ts",
    "**/app-bundles.ts",
    "**/plugin-bundle.ts",
    "**/inlined.generated.ts",
    "**/public/**",
    "**/mcp-apps/**/dist/**"
  ],
  "format": ["typescript", "tsx", "javascript", "jsx", "python"],
  "minLines": 10,
  "minTokens": 50,
  "maxLines": 1000,
  "maxSize": "200kb",
  "mode": "mild",
  "absolute": true,
  "skipLocal": false,
  "exitCode": 0
}
